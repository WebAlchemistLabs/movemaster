# ─── Backend API ──────────────────────────────────────────────────────────────
# Point to your running Express server to enable real auth, quotes, and emails
# Leave blank to use the built-in localStorage demo mode
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Firebase (optional - enables real auth + Firestore) ──────────────────────
# Without these, the app runs in full demo mode using localStorage
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Stripe (optional - enables real deposit payments) ────────────────────────
# Without these, payments are simulated in demo mode
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ─── Google Maps (optional - enables city map views) ──────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
