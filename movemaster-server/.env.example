PORT=4000
NODE_ENV=development
API_VERSION=v1

JWT_SECRET=movemaster-secret-key-change-in-production
JWT_REFRESH_SECRET=movemaster-refresh-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Email (optional — emails logged to console without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MoveMaster Pro <hello@movemasterpro.ca>
ADMIN_EMAIL=admin@movemasterpro.ca
