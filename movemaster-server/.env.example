# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_VERSION=v1

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Firebase Admin ────────────────────────────────────────
# Option A: JSON key file path
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: Individual env vars (use one or the other)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEPOSIT_PERCENT=20

# ─── Email (Nodemailer) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@movemasterpro.ca
SMTP_PASS=your_app_password
EMAIL_FROM=MoveMaster Pro <hello@movemasterpro.ca>
ADMIN_EMAIL=admin@movemasterpro.ca

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://movemasterpro.ca

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_QUOTE_MAX=10

# ─── Demo Mode (set to true to skip Firebase/Stripe) ───────
DEMO_MODE=true
